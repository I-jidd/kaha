# PostgreSQL
POSTGRES_DB=kaha_db
POSTGRES_USER=kaha_user
POSTGRES_PASSWORD=kaha_password
POSTGRES_PORT=5433

# Backend database URL for later SQLAlchemy setup
DATABASE_URL=postgresql+psycopg2://kaha_user:kaha_password@localhost:5433/kaha_db

JWT_SECRET_KEY=a-very-long-random-secret-string-at-least-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60